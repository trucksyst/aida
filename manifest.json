{
  "manifest_version": 3,
  "minimum_chrome_version": "114",
  "name": "AIDA — AI Dispatcher",
  "short_name": "AIDA",
  "version": "0.2.13",
  "description": "Персональный инструмент диспетчера. Агрегирует грузы со всех лоадбордов в одном окне.",
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "AIDA Dispatcher"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms",
    "cookies",
    "webRequest",
    "identity"
  ],
  "oauth2": {
    "client_id": "156258598437-hvrda4k088gqog76o1mkk4rh6ti2ujdu.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/cloud-platform"
    ]
  },
  "host_permissions": [
    "https://one.dat.com/*",
    "https://login.dat.com/*",
    "https://freight.api.dat.com/*",
    "https://freight.api.prod.dat.com/*",
    "https://identity.api.dat.com/*",
    "https://www.truckstop.com/*",
    "https://main.truckstop.com/*",
    "https://auth.truckstop.com/*",
    "https://v5-auth.truckstop.com/*",
    "https://app.truckstop.com/*",
    "https://api.truckstop.com/*",
    "https://truckstop.com/*",
    "https://loadsearch-graphql-api-prod.truckstop.com/*",
    "https://loadboard.truckerpath.com/*",
    "https://api.truckerpath.com/*",
    "https://members.123loadboard.com/*",
    "https://login.123loadboard.com/*",
    "https://api.retellai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://aiplatform.googleapis.com/*",
    "https://*.aiplatform.googleapis.com/*",
    "https://nominatim.openstreetmap.org/*",
    "https://router.project-osrm.org/*",
    "https://tile.openstreetmap.org/*"
  ],
  "content_scripts": []
}